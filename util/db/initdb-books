#!/bin/sh
# Build a book-review oriented CCSO database from books.input/books.cnf.

echo "Book database build script started..."
cd /opt/nameserv

cp util/db/books.cnf prod-new.cnf
cp util/db/books.input qi.input

echo "Calculating size..."
size=`./bin/sizedb prod-new.cnf qi.input`

echo "Executing credb..."
./bin/credb $size prod-new
echo "Executing maked..."
./bin/maked prod-new <qi.input
echo "Executing makei..."
./bin/makei prod-new
echo "Executing build..."
./bin/build -s prod-new

echo "Moving database into place..."
for ext in bdx bnr dir dov idx iov lck seq cnf; do
    if [ -f "prod-new.$ext" ]; then
        mv "prod-new.$ext" "db/prod.$ext"
    fi
done

echo "Book database build script complete."
